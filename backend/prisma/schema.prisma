generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CategoryFormat {
  INDIVIDUAL
  TEAM_PAIRS
}

enum RaceType {
  PUNKTEFAHREN
  TEMPORUNDEN
  VERFOLGUNGSRENNEN
}

enum RaceStatus {
  SETUP
  ACTIVE
  FINISHED
}

enum TimeStatus {
  OK
  DNS
  DNF
}

enum FlagType {
  DSQ
  WARNING
}

enum DocType {
  STARTLISTE
  ERGEBNIS
  SONSTIGES
}

model Event {
  id         String     @id @default(cuid())
  name       String
  date       DateTime?
  location   String?
  categories Category[]
  createdAt  DateTime   @default(now())

  communiqueSource CommuniqueSource?
}

model Category {
  id      String         @id @default(cuid())
  eventId String
  event   Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name    String
  format  CategoryFormat @default(INDIVIDUAL)
  teams   Team[]
  races   Race[]
}

model Team {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  number     Int
  name       String
  club       String?
  isFavorite Boolean  @default(false)
  rider1     String?
  rider2     String?
  color      String?
  pattern    String?

  omniumScores  OmniumScore[]
  sprintResults SprintResult[]
  lapEvents     LapEvent[]
  timeResults   TimeResult[]
  raceFlags     RaceFlag[]
  pursuitTeam1  PursuitRound[] @relation("team1")
  pursuitTeam2  PursuitRound[] @relation("team2")
  pursuitWinner PursuitRound[] @relation("winner")

  @@unique([categoryId, number])
}

model Race {
  id           String          @id @default(cuid())
  categoryId   String
  category     Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  type         RaceType
  format       CategoryFormat?
  name         String
  status       RaceStatus      @default(SETUP)
  order        Int             @default(0)
  finaleActive Boolean         @default(true)
  createdAt    DateTime        @default(now())

  omniumScores  OmniumScore[]
  sprints       Sprint[]
  lapEvents     LapEvent[]
  timeResults   TimeResult[]
  pursuitRounds PursuitRound[]
  flags         RaceFlag[]
}

model RaceFlag {
  id        String   @id @default(cuid())
  raceId    String
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  type      FlagType
  createdAt DateTime @default(now())

  @@unique([raceId, teamId, type])
}

model OmniumScore {
  id     String @id @default(cuid())
  raceId String
  race   Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id])
  points Int    @default(0)

  @@unique([raceId, teamId])
}

model Sprint {
  id       String         @id @default(cuid())
  raceId   String
  race     Race           @relation(fields: [raceId], references: [id], onDelete: Cascade)
  number   Int
  isFinale Boolean        @default(false)
  results  SprintResult[]

  @@unique([raceId, number])
}

model SprintResult {
  id       String @id @default(cuid())
  sprintId String
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id])
  position Int

  @@unique([sprintId, position])
  @@unique([sprintId, teamId])
}

model LapEvent {
  id        String   @id @default(cuid())
  raceId    String
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  delta     Int
  note      String?
  createdAt DateTime @default(now())
}

model TimeResult {
  id     String     @id @default(cuid())
  raceId String
  race   Race       @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId String
  team   Team       @relation(fields: [teamId], references: [id])
  timeMs Int?
  status TimeStatus @default(OK)

  @@unique([raceId, teamId])
}

model PursuitRound {
  id       String  @id @default(cuid())
  raceId   String
  race     Race    @relation(fields: [raceId], references: [id], onDelete: Cascade)
  round    String
  heat     Int
  team1Id  String?
  team1    Team?   @relation("team1",  fields: [team1Id],  references: [id])
  team2Id  String?
  team2    Team?   @relation("team2",  fields: [team2Id],  references: [id])
  time1Ms  Int?
  time2Ms  Int?
  winnerId String?
  winner   Team?   @relation("winner", fields: [winnerId], references: [id])
}

model PursuitPlan {
  id         String   @id @default(cuid())
  trackM     Float
  numRounds  Int
  anfahrtSec Float
  lapSec     Float
  totalSec   Float
  selectedKb Int?
  selectedRz Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Kommuniqué-Notifier ────────────────────────────────────────────────────

model CommuniqueSource {
  id         String   @id @default(cuid())
  eventId    String   @unique
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  shareToken String   // Token aus der Nextcloud-Share-URL
  label      String?  // optionaler Anzeigename, z.B. "LVM Bahn 2026"
  lastPolledAt DateTime?
  createdAt  DateTime @default(now())

  documents     CommuniqueDocument[]
  subscriptions PushSubscription[]
}

model CommuniqueDocument {
  id           String           @id @default(cuid())
  sourceId     String
  source       CommuniqueSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  fileName     String
  docType      DocType          @default(SONSTIGES)
  ak           String           @default("Alle") // z.B. "U17m", "Elite w", "Alle"
  remoteModifiedAt DateTime      // Änderungsdatum laut WebDAV
  discoveredAt DateTime         @default(now())

  @@unique([sourceId, fileName])
}

model PushSubscription {
  id        String           @id @default(cuid())
  sourceId  String
  source    CommuniqueSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  endpoint  String           @unique
  p256dh    String
  auth      String
  akFilter  String[]         @default(["Alle"]) // leer/["Alle"] = alle Klassen
  createdAt DateTime         @default(now())
}
