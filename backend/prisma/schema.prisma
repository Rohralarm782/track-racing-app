generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CategoryFormat {
  INDIVIDUAL
  TEAM_PAIRS
}

enum RaceType {
  PUNKTEFAHREN
  TEMPORUNDEN
  VERFOLGUNGSRENNEN
}

enum RaceStatus {
  SETUP
  ACTIVE
  FINISHED
}

enum TimeStatus {
  OK
  DNS
  DNF
}

enum FlagType {
  DSQ
  WARNING
  DNS
}

enum DocType {
  STARTLISTE
  ERGEBNIS
  ZEITPLAN
  SONSTIGES
}

enum Discipline {
  SPRINT
  AUSDAUER
  ALLGEMEIN
}

enum ScheduleEntryType {
  RACE
  CEREMONY
  INFO
}

enum LiveStatusKey {
  STARTING
  RUNNING
  FINISHED
  STARTS_AT
}

model Event {
  id         String     @id @default(cuid())
  name       String
  date       DateTime?
  location   String?
  categories Category[]
  races      Race[]     // neu: Rennen, die direkt an der Veranstaltung hängen (ohne Kategorie)
  createdAt  DateTime   @default(now())

  communiqueSource CommuniqueSource?
  scheduleEntries  ScheduleEntry[]
  status           EventStatus?
  statusLog        StatusUpdateLog[]
}

model Category {
  id      String         @id @default(cuid())
  eventId String
  event   Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name    String
  format  CategoryFormat @default(INDIVIDUAL)
  teams   Team[]
  races   Race[]
}

model Team {
  id         String    @id @default(cuid())
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  raceId     String?   // neu: direkte Zugehörigkeit für Rennen ohne Kategorie
  race       Race?     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  number     Int
  name       String
  club       String?
  lv         String?  // Landesverband (z.B. "MEV", "NRW") des ersten Fahrers/Teams
  rider2Lv   String?  // Landesverband des zweiten Fahrers bei Paaren (Madison)
  isFavorite Boolean  @default(false)
  rider1     String?
  rider2     String?
  color      String?
  pattern    String?

  omniumScores  OmniumScore[]
  sprintResults SprintResult[]
  lapEvents     LapEvent[]
  timeResults   TimeResult[]
  raceFlags     RaceFlag[]
  pursuitTeam1  PursuitRound[] @relation("team1")
  pursuitTeam2  PursuitRound[] @relation("team2")
  pursuitWinner PursuitRound[] @relation("winner")

  @@unique([categoryId, number])
  @@unique([raceId, number])
}

model Race {
  id           String          @id @default(cuid())
  categoryId   String?
  category     Category?       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  eventId      String?         // neu: direkte Zugehörigkeit ohne Kategorie
  event        Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ak           String?         // neu: Altersklassen-Tag nur zum Anzeigen/Suchen (z.B. "U17m"), keine echte Beziehung
  teams        Team[]          // neu: eigene Teams für Rennen ohne Kategorie
  type         RaceType
  format       CategoryFormat?
  name         String
  status       RaceStatus      @default(SETUP)
  order        Int             @default(0)
  finaleActive Boolean         @default(true)
  plannedSprints Int?          // aus Ansetzung erkannte Anzahl Wertungen — die letzte wird automatisch als Finale gewertet
  distanceM    Int?            // grobe Distanz in Metern (Verfolgungsrennen) — für Sportlerprofil-Anzeige, optional
  createdAt    DateTime        @default(now())

  omniumScores  OmniumScore[]
  sprints       Sprint[]
  lapEvents     LapEvent[]
  timeResults   TimeResult[]
  pursuitRounds PursuitRound[]
  flags         RaceFlag[]
  athletes      RaceAthlete[]  // neu: verknüpfte Sportler aus der eigenen Kartei (Verfolgungsrennen)
}

model RaceFlag {
  id        String   @id @default(cuid())
  raceId    String
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  type      FlagType
  createdAt DateTime @default(now())

  @@unique([raceId, teamId, type])
}

model OmniumScore {
  id     String @id @default(cuid())
  raceId String
  race   Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  points Int    @default(0)

  @@unique([raceId, teamId])
}

model Sprint {
  id       String         @id @default(cuid())
  raceId   String
  race     Race           @relation(fields: [raceId], references: [id], onDelete: Cascade)
  number   Int
  isFinale Boolean        @default(false)
  results  SprintResult[]

  @@unique([raceId, number])
}

model SprintResult {
  id       String @id @default(cuid())
  sprintId String
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  position Int

  @@unique([sprintId, position])
  @@unique([sprintId, teamId])
}

model LapEvent {
  id        String   @id @default(cuid())
  raceId    String
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  delta     Int
  note      String?
  createdAt DateTime @default(now())
}

model TimeResult {
  id     String     @id @default(cuid())
  raceId String
  race   Race       @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId String
  team   Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  timeMs Int?
  status TimeStatus @default(OK)

  @@unique([raceId, teamId])
}

model PursuitRound {
  id       String  @id @default(cuid())
  raceId   String
  race     Race    @relation(fields: [raceId], references: [id], onDelete: Cascade)
  round    String
  heat     Int
  team1Id  String?
  team1    Team?   @relation("team1",  fields: [team1Id],  references: [id])
  team2Id  String?
  team2    Team?   @relation("team2",  fields: [team2Id],  references: [id])
  time1Ms  Int?
  time2Ms  Int?
  winnerId String?
  winner   Team?   @relation("winner", fields: [winnerId], references: [id])
}

model PursuitPlan {
  id         String   @id @default(cuid())
  trackM     Float
  numRounds  Int
  anfahrtSec Float
  lapSec     Float
  totalSec   Float
  selectedKb Int?
  selectedRz Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Sportlerkartei ─────────────────────────────────────────────────────────
// Bewusst schlank gehalten: nur die eigenen Sportler, keine automatische
// Zuordnung zu importierten Startlisten/Meldelisten. Die Verknüpfung mit
// einem Verfolgungsrennen läuft direkt über RaceAthlete, unabhängig vom
// bestehenden Team-Modell (das für Verfolgungsrennen ohnehin nicht für die
// Wertung genutzt wird — siehe RaceDetail.tsx, VERFOLGUNGSRENNEN-Zweig).
model Athlete {
  id             String   @id @default(cuid())
  name           String
  ak             String?  // Altersklasse, freier Text, z.B. "U17 m"
  notes          String?
  kettenblaetter Int[]    @default([]) // verfügbare Kettenblätter (Zähne) — frei kombinierbar, kein fester Satz
  ritzel         Int[]    @default([]) // verfügbare Ritzel (Zähne) — frei kombinierbar, kein fester Satz
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  raceLinks      RaceAthlete[]
}

// Verknüpfung Sportler ↔ Verfolgungsrennen ("wer war dabei"). timeMs bleibt
// vorerst ungenutzt (null) — die Ergebnis-Übernahme aus dem Renntimer ist ein
// späterer Ausbauschritt, das Feld ist aber schon vorbereitet.
model RaceAthlete {
  id        String   @id @default(cuid())
  raceId    String
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  timeMs    Int?
  createdAt DateTime @default(now())

  @@unique([raceId, athleteId])
}

// ─── Kommuniqué-Notifier ────────────────────────────────────────────────────

model CommuniqueSource {
  id         String   @id @default(cuid())
  eventId    String   @unique
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  shareToken String   // Token aus der Nextcloud-Share-URL
  label      String?  // optionaler Anzeigename, z.B. "LVM Bahn 2026"
  lastPolledAt DateTime?
  createdAt  DateTime @default(now())

  documents     CommuniqueDocument[]
  subscriptions PushSubscription[]
}

model CommuniqueDocument {
  id           String           @id @default(cuid())
  sourceId     String
  source       CommuniqueSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  fileName     String
  docType      DocType          @default(SONSTIGES)
  ak           String           @default("Alle") // z.B. "U17m", "Elite w", "Alle"
  discipline   Discipline       @default(ALLGEMEIN)
  isPinned     Boolean          @default(false)
  remoteModifiedAt DateTime      // Änderungsdatum laut WebDAV
  discoveredAt DateTime         @default(now())

  // ─── Für die Zeitplan-Verknüpfung (Disziplin-Kürzel/Phase aus dem Dateinamen) ──
  disciplineCode String?  // z.B. "MA", "PR", "OM", "TR", "VF" — aus Dateinamen erkannt
  phaseLabel     String?  // z.B. "1. VL", "A-Lauf", "Finale" — aus Dateinamen erkannt

  // ─── MEV-Erkennung (nur bei STARTLISTE-Dokumenten, per Hintergrund-Analyse) ──
  mevNames      String[]  @default([]) // Namen erkannter MEV-Fahrer/Teams (nur Namen, für Abwärtskompatibilität)
  mevRiders     Json      @default("[]") // [{ name: string, lauf: number | null }] — wie mevNames, zusätzlich mit Lauf-Nummer bei Einzelstart-Formaten
  heatCount     Int?      // Gesamtzahl unterschiedlicher Läufe (Einzelstart-Formate wie Zeitfahren/Verfolgung)
  starterCount  Int?      // Gesamtzahl Starter/Teams laut Tabelle
  roundCount    Int?      // Rundenzahl des Rennens (Massenstart-Formate); bei Ausscheidungsfahren = starterCount*2 statt Textfund (siehe mevDetect.ts)
  mevAnalyzedAt DateTime? // wann die MEV-Analyse zuletzt gelaufen ist (null = noch nicht analysiert)

  scheduleEntry ScheduleEntry?
  // Reverse von linkedResultDocumentId (siehe ScheduleEntry) — falls DIESES
  // Dokument als Ergebnis zu einem Zeitplan-Eintrag verknüpft ist.
  scheduleEntryAsResult ScheduleEntry? @relation("ScheduleEntryResult")
  // Zeitplan-Einträge, die aus DIESEM Dokument automatisch importiert wurden
  // (nur bei docType=ZEITPLAN relevant) — siehe sourceDocumentId oben.
  sourceForEntries ScheduleEntry[] @relation("ScheduleEntrySource")

  @@unique([sourceId, fileName])
}

model PushSubscription {
  id        String           @id @default(cuid())
  sourceId  String
  source    CommuniqueSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  endpoint  String           @unique
  p256dh    String
  auth      String
  akFilter  String[]         @default(["Alle"]) // leer/["Alle"] = alle Klassen
  disciplineFilter String[]  @default(["Alle"]) // leer/["Alle"] = Sprint + Ausdauer
  createdAt DateTime         @default(now())
}

// ─── Zeitplan ───────────────────────────────────────────────────────────────
// Rein informativer, von der Wettkampf-Datenmodellierung (Race/Sprint/...)
// getrennter Ablaufplan der Veranstaltung — importiert aus dem Zeitplan-PDF.
// Jeder Eintrag kann optional mit dem passenden Kommuniqué (Ansetzung)
// verknüpft werden, um MEV-Starter direkt im Zeitplan sichtbar zu machen.

model ScheduleEntry {
  id              String            @id @default(cuid())
  eventId         String
  event           Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  day             Int               // fortlaufende Nummer innerhalb der Veranstaltung, 1 = erster Tag, 2 = zweiter, ...
  dayLabel        String?           // Wochentag laut Dokument (z.B. "Mittwoch") — dient NUR der Dubletten-Erkennung
                                     // beim (Auto-)Import (siehe scheduleImport.ts), unabhängig vom Kalenderdatum,
                                     // das in manchen Zeitplan-PDFs fehlerhaft ist. Kein Anzeige-Feld.
  time            String            // "HH:MM" laut Zeitplan-PDF, rein informativ (siehe EventStatus für Live-Korrektur)
  ak              String            // Altersklasse, z.B. "U17m" — freier Text aus dem Zeitplan, keine echte Beziehung
  disciplineLabel String            // Disziplin als Klartext, z.B. "Punktefahren", "Omnium Scratch"
  phase           String?           // Phase, z.B. "1. Vorlauf", "Finale", "A-Lauf"
  type            ScheduleEntryType @default(RACE)
  massStart       Boolean           @default(false) // true = Massenstart-Format, Starterzahl wird nicht angezeigt
  order           Int               // Reihenfolge über die gesamte Veranstaltung hinweg

  linkedDocumentId String?             @unique
  linkedDocument    CommuniqueDocument? @relation(fields: [linkedDocumentId], references: [id], onDelete: SetNull)

  // Verknüpftes Ergebnis-Kommuniqué, sobald verfügbar — bewusst getrennt von
  // linkedDocument (Startliste/Ansetzung), damit die dortigen MEV-Namen auch
  // nach Veröffentlichung des Ergebnisses weiter angezeigt werden können.
  linkedResultDocumentId String?             @unique
  linkedResultDocument    CommuniqueDocument? @relation("ScheduleEntryResult", fields: [linkedResultDocumentId], references: [id], onDelete: SetNull)

  // Welches ZEITPLAN-Kommuniqué diesen Eintrag automatisch erzeugt hat (siehe
  // autoImportScheduleFromDocument). Getrennt von linkedDocumentId (das die
  // passende Ansetzung/Ergebnis für die Renn-Anzeige verknüpft), weil reale
  // Zeitpläne oft aus einem PDF PRO VERANSTALTUNGSTAG bestehen — beim
  // (Re-)Import eines Tages dürfen die Einträge der anderen Tage nicht
  // gelöscht werden. NICHT @unique: ein Dokument erzeugt viele Einträge.
  sourceDocumentId String?
  sourceDocument   CommuniqueDocument? @relation("ScheduleEntrySource", fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // Manuell eingetragene Runden-/Laufzahl für die Zeitschätzung — überschreibt
  // sowohl eine aus der Startliste extrahierte Zahl als auch die allgemeine
  // Rückfallgröße (siehe AppSettings). Rein informativ für durationEstimate.ts,
  // ändert nichts an der eigentlichen Renn-Wertung.
  manualUnitCount Int?

  liveStatus EventStatus?
  statusLogEntries StatusUpdateLog[]

  @@index([eventId, order])
}

// ─── Aktueller Stand ────────────────────────────────────────────────────────
// Singleton pro Event: manuell per Knopfdruck aktualisierter "wo stehen wir
// gerade"-Status, unabhängig davon ob das jeweilige Rennen in der App selbst
// gewertet wird. offsetMinutes wird beim Speichern einmalig aus der echten
// Uhrzeit minus der geplanten Uhrzeit des gewählten Zeitplan-Eintrags berechnet.

model EventStatus {
  id              String        @id @default(cuid())
  eventId         String        @unique
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scheduleEntryId String        @unique
  scheduleEntry   ScheduleEntry @relation(fields: [scheduleEntryId], references: [id], onDelete: Cascade)
  statusKey       LiveStatusKey
  roundsLeft      Int?
  offsetMinutes   Int           @default(0)
  updatedAt       DateTime      @updatedAt
}

// ─── Zeitschätzung ──────────────────────────────────────────────────────────
// Verlaufsprotokoll JEDER "Aktueller Stand"-Meldung (im Unterschied zu
// EventStatus oben, das nur den jeweils LETZTEN Stand als Singleton hält).
// Grundlage für die Selbstkalibrierung: aus der Zeitspanne zwischen zwei
// aufeinanderfolgenden Meldungen und den dazwischen liegenden Zeitplan-
// Einträgen lässt sich ableiten, ob die aktuelle Schätzung zu hoch oder zu
// niedrig lag (siehe recalibrateFromStatusUpdate in durationEstimate.ts).
model StatusUpdateLog {
  id              String        @id @default(cuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scheduleEntryId String
  scheduleEntry   ScheduleEntry @relation(fields: [scheduleEntryId], references: [id], onDelete: Cascade)
  statusKey       LiveStatusKey
  createdAt       DateTime      @default(now())

  @@index([eventId, createdAt])
}

// Ein einziger Korrekturfaktor pro Kategorie (Altersklasse + Disziplin +
// Massenstart ja/nein), der die feste Ausgangsformel (siehe
// durationEstimate.ts, Werte aus Haukes Erfahrung) hoch- oder runterskaliert.
// Startet bei 1.0 (= Ausgangsformel unverändert) und wird bei jeder
// "Aktueller Stand"-Meldung leicht in Richtung der beobachteten Realität
// verschoben — je mehr Beobachtungen (sampleCount), desto kleiner der
// nächste Ausschlag, damit sich der Wert mit der Zeit stabilisiert statt zu
// überschwingen.
model DurationEstimate {
  id               String   @id @default(cuid())
  ak               String
  disciplineLabel  String
  massStart        Boolean
  correctionFactor Float    @default(1.0)
  sampleCount      Int      @default(0)
  updatedAt        DateTime @updatedAt

  @@unique([ak, disciplineLabel, massStart])
}

// ─── Allgemeine Einstellungen ───────────────────────────────────────────────
// Singleton (immer genau eine Zeile, id fest "singleton") — gilt für die
// gesamte App, nicht pro Veranstaltung. Enthält alles, was bisher als feste
// Konstante in durationEstimate.ts/mevDetect.ts stand, jetzt editierbar über
// die Einstellungen-Seite, ohne dass dafür Code geändert werden muss.
model AppSettings {
  id String @id @default("singleton")

  // Landesverband-Kürzel, nach dem in Startlisten gesucht wird (MEV-Erkennung,
  // Lauf-Nummer, Team-Namen). Macht die App über MEV hinaus wiederverwendbar.
  mevLv String @default("MEV")

  // Massenstart-Formel: Startaufstellung + (Min./Runde × Runden) + Abräumen
  massStartSetupMin    Float @default(5)
  massStartPerRoundMin Float @default(0.3333333333333333) // 20 Sek.
  massStartClearMin    Float @default(3)

  // Ausscheidungsfahren: eigene, kürzere Werte (Rundenzahl = Starter×2, siehe mevDetect.ts)
  afSetupMin    Float @default(3)
  afPerRoundMin Float @default(0.3333333333333333)
  afClearMin    Float @default(2)

  // Verfolgung/Zeitfahren: Startaufstellung + übliche Renndauer (siehe
  // distanceRaceMinutes), pro Lauf, mal Laufzahl
  pursuitSetupMin Float @default(1)
  // JSON-Objekt {"4000m": 4.5, "3000m": 3.5, "2000m": 2.5, "1000m": 1.1, "500m": 0.583, "default": 3.0}
  distanceRaceMinutes Json @default("{\"4000m\":4.5,\"3000m\":3.5,\"2000m\":2.5,\"1000m\":1.1,\"500m\":0.583,\"default\":3.0}")

  sprintPerHeatMin     Float @default(2)
  teamsprintPerHeatMin Float @default(2)
  keirinPerHeatMin     Float @default(4)

  pauseBufferMin       Int @default(20) // Cool-down nach dem letzten Rennen eines Blocks
  estimateThresholdMin Int @default(5)  // Schätzung nur anzeigen, wenn Abweichung > diesem Wert

  // Rückfallgrößen, wenn die Startliste keine Runden-/Laufzahl hergibt
  fallbackRoundCountPr      Int @default(50) // Punktefahren
  fallbackRoundCountTr      Int @default(30) // Temporunden
  fallbackRoundCountDefault Int @default(30) // Madison, Scratch, Omnium, ...
  fallbackHeatCount         Int @default(8)  // Einzelstart generisch (z.B. Quali)
  pursuitFinalHeatCount     Int @default(2)  // Verfolgung/Zeitfahren-Finale (strukturell fest)

  updatedAt DateTime @updatedAt
}
